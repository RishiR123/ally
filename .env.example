# Ally Configuration

# Set this to your local provider's base URL (e.g., LM Studio, Ollama via OpenAI proxy)
# ALLY_API_BASE_URL=http://localhost:1234/v1

# The API key (usually not required for local models, but OpenAI requires something)
# ALLY_API_KEY=lm-studio

# The model to use
# ALLY_MODEL=local-model
